{
   "action": {
      "default_icon": {
         "128": "images/icon128.png",
         "16": "images/icon16.png",
         "32": "images/icon32.png",
         "48": "images/icon48.png"
      },
      "default_title": "Flow Image Automator - Bulk AI Image Generation for Google Labs"
   },
   "background": {
      "service_worker": "background.js",
      "type": "module"
   },
   "content_scripts": [ {
      "js": [ "flowContentScript.js" ],
      "matches": [ "https://labs.google/fx/tools/flow/*", "https://labs.google/fx/*/tools/flow/*" ],
      "run_at": "document_idle"
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'"
   },
   "description": "Automate Google Labs image generation. Bulk create AI images with Imagen 4, Nano Bana 2, and Nano Banana Pro models.",
   "host_permissions": [ "https://labs.google/*", "http://*/*", "https://*/*" ],
   "icons": {
      "128": "images/icon128.png",
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png"
   },
   "manifest_version": 3,
   "name": "Flow Image Automator - Bulk AI Image Generation for Google Labs",
   "permissions": [ "activeTab", "storage", "sidePanel", "tabs", "scripting", "downloads" ],
   "side_panel": {
      "default_path": "./src/index.html"
   },
   "version": "2.0.1",
   "web_accessible_resources": [ {
      "matches": [ "https://labs.google/*" ],
      "resources": [ "alwaysActive.js", "alwaysActiveIsolated.js" ]
   } ]
}
